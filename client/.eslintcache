 '$spin 2s step-start infinite',\n  },\n  text: {\n    fontWeight: 700,\n  },\n}))\n\nconst Loading = () => {\n  const classes = useStyles()\n\n  return (\n    <div className={classes.root}>\n      <div className={classes.inner}>\n        <LogoIcon className={classes.logoIcon} />\n        {/* <Typography className={classes.text} variant=\"h6\" component=\"p\">\n          LOADING\n        </Typography> */}\n      </div>\n    </div>\n  )\n}\n\nexport default Loading\n","/home/bryan/Documents/node/apps/finatic/client/src/shared/utils/numberFormat.js",[],"/home/bryan/Documents/node/apps/finatic/client/src/shared/components/Link.jsx",[],"/home/bryan/Documents/node/apps/finatic/client/src/Market/Tabs.jsx",["148"],"/home/bryan/Documents/node/apps/finatic/client/src/shared/hooks/useWindowSize.js",[],"/home/bryan/Documents/node/apps/finatic/client/src/shared/context/SmallScreenContext.js",[],["149","150"],"/home/bryan/Documents/node/apps/finatic/client/src/shared/hooks/useUnderBreakpoint.js",[],"/home/bryan/Documents/node/apps/finatic/client/src/shared/components/Icon.jsx",[],"/home/bryan/Documents/node/apps/finatic/client/src/Market/Table/index.jsx",[],["151","152"],"/home/bryan/Documents/node/apps/finatic/client/src/Market/Table/Table.jsx",[],"/home/bryan/Documents/node/apps/finatic/client/src/Market/Table/TableHead.jsx",[],"/home/bryan/Documents/node/apps/finatic/client/src/News/index.jsx",[],"/home/bryan/Documents/node/apps/finatic/client/src/News/images.js",[],"/home/bryan/Documents/node/apps/finatic/client/src/App/App.jsx",[],"/home/bryan/Documents/node/apps/finatic/client/src/Company/index.jsx",[],"/home/bryan/Documents/node/apps/finatic/client/src/Company/StockChart/index.jsx",[],"/home/bryan/Documents/node/apps/finatic/client/src/Company/StockChart/tooltip.js",[],"/home/bryan/Documents/node/apps/finatic/client/src/Company/StockChart/createOptions.js",[],"/home/bryan/Documents/node/apps/finatic/client/src/Market/ReactTable.jsx",[],"/home/bryan/Documents/node/apps/fin